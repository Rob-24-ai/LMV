# Copy to .env.local and fill in. The app reads ANTHROPIC_API_KEY server-side only.
ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides (defaults shown):
# LMV_MODEL_DATING=claude-opus-4-8
# LMV_MODEL_WRITING=claude-sonnet-4-6

# Set on the hosted deploy ONLY — locks the whole app behind a shared passcode
# (HTTP Basic auth). Leave unset locally so Max-mode dev stays open.
# LMV_PASSCODE=choose-a-strong-passcode
